# ──────────────────────────────────────────────────────────────────────────────
# Example secrets for the survey system.
#
# Copy to `.streamlit/secrets.toml` (which is gitignored) for local use, OR set
# the SAME keys as environment variables on Heroku / DigitalOcean. The app reads
# environment variables first and falls back to this file.
#
# DO NOT commit the real secrets.toml.
# ──────────────────────────────────────────────────────────────────────────────

# Production database. Leave UNSET locally to use a local SQLite file.
# On Heroku/DigitalOcean a managed Postgres add-on provides this automatically.
# DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# Password for the researcher dashboard at /?admin=1  (required to unlock it).
SURVEY_ADMIN_PASSWORD = "change-me"

# Set to "0" to disable the survey gate and run the bare simulator.
SURVEY_ENABLED = "1"

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Google Sheets secondary mirror.
# Leave this whole section out to store data only in the primary database.
#
# Setup: create a Google Cloud service account, enable the Google Sheets API,
# download its JSON key, create a Sheet, and share it (Editor) with the service
# account's client_email. Then paste the sheet id/URL and the key below.
# ──────────────────────────────────────────────────────────────────────────────

# gsheets_id = "1AbC…the long id from the sheet URL…XyZ"   # id or full URL

# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "…"
# private_key = "-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n"
# client_email = "qkd-survey@your-project.iam.gserviceaccount.com"
# client_id = "…"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "…"
# universe_domain = "googleapis.com"
